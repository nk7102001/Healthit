<% layout("layouts/boilerplate") %>
<% title = "Features - Healthit" %>

<div class="page-hero">
  <div class="max-w-6xl mx-auto">
    <div class="section-badge" style="background:rgba(34,197,94,0.15);border-color:rgba(34,197,94,0.3);">🌟 Platform Features</div>
    <h1 class="page-hero-title mt-2">Everything You Need to<br>Live Healthier</h1>
    <p class="page-hero-subtitle">A complete wellness ecosystem built for your health goals</p>
  </div>
</div>

<main class="flex-1 px-4 py-16 max-w-6xl mx-auto w-full">

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

    <a href="/bmi" class="feature-card reveal reveal-delay-1" style="text-decoration:none;display:block;">
      <div class="feature-icon-wrap">📏</div>
      <h2 style="font-family:'Sora',sans-serif;font-weight:700;font-size:1.3rem;margin-bottom:.6rem;color:var(--dark);">BMI Calculator</h2>
      <p style="color:var(--gray-600);line-height:1.7;font-size:.95rem;">Instantly calculate your Body Mass Index and get a clear understanding of your health status. Track your BMI history over time to monitor progress.</p>
      <span class="btn btn-outline btn-sm" style="margin-top:1.25rem;pointer-events:none;">Try BMI Calculator →</span>
    </a>

    <a href="/nearby" class="feature-card reveal reveal-delay-2" style="text-decoration:none;display:block;">
      <div class="feature-icon-wrap">🏥</div>
      <h2 style="font-family:'Sora',sans-serif;font-weight:700;font-size:1.3rem;margin-bottom:.6rem;color:var(--dark);">Nearby Hospitals</h2>
      <p style="color:var(--gray-600);line-height:1.7;font-size:.95rem;">Find hospitals and medical stores near your location instantly. Search by city and filter by hospital or pharmacy to get directions fast.</p>
      <span class="btn btn-outline btn-sm" style="margin-top:1.25rem;pointer-events:none;">Find Nearby Services →</span>
    </a>

    <a href="/exercises" class="feature-card reveal reveal-delay-1" style="text-decoration:none;display:block;">
      <div class="feature-icon-wrap">🏋️</div>
      <h2 style="font-family:'Sora',sans-serif;font-weight:700;font-size:1.3rem;margin-bottom:.6rem;color:var(--dark);">Home Exercise Library</h2>
      <p style="color:var(--gray-600);line-height:1.7;font-size:.95rem;">Access a complete library of guided home workouts with video demonstrations. Filter by body part — Upper Body, Core, Cardio, and more.</p>
      <span class="btn btn-outline btn-sm" style="margin-top:1.25rem;pointer-events:none;">View Exercises →</span>
    </a>

    <a href="/ai-plan" class="feature-card reveal reveal-delay-2" style="text-decoration:none;display:block;">
      <div class="feature-icon-wrap">🤖</div>
      <h2 style="font-family:'Sora',sans-serif;font-weight:700;font-size:1.3rem;margin-bottom:.6rem;color:var(--dark);">AI-Powered Plans</h2>
      <p style="color:var(--gray-600);line-height:1.7;font-size:.95rem;">Get a personalized diet and workout plan generated by AI. Input your goal, age, gender, and activity level to receive a custom health roadmap.</p>
      <span class="btn btn-outline btn-sm" style="margin-top:1.25rem;pointer-events:none;">Generate Plan →</span>
    </a>

    <a href="/blog" class="feature-card reveal reveal-delay-2" style="text-decoration:none;display:block;">
      <div class="feature-icon-wrap">📝</div>
      <h2 style="font-family:'Sora',sans-serif;font-weight:700;font-size:1.3rem;margin-bottom:.6rem;color:var(--dark);">Health Blog</h2>
      <p style="color:var(--gray-600);line-height:1.7;font-size:.95rem;">Stay informed with expertly written articles on nutrition, fitness, mental wellness, and healthy habits to keep you motivated on your journey.</p>
      <span class="btn btn-outline btn-sm" style="margin-top:1.25rem;pointer-events:none;">Read Blog →</span>
    </a>

    <a href="/dashboard" class="feature-card reveal reveal-delay-3" style="text-decoration:none;display:block;">
      <div class="feature-icon-wrap">📊</div>
      <h2 style="font-family:'Sora',sans-serif;font-weight:700;font-size:1.3rem;margin-bottom:.6rem;color:var(--dark);">Progress Dashboard</h2>
      <p style="color:var(--gray-600);line-height:1.7;font-size:.95rem;">Your personal health hub — view BMI history, manage AI plans, edit profile details, and track your entire wellness journey in one place.</p>
      <span class="btn btn-outline btn-sm" style="margin-top:1.25rem;pointer-events:none;">View Dashboard →</span>
    </a>

  </div>

  <!-- CTA -->
  <div class="text-center mt-16 reveal">
    <h3 style="font-family:'Sora',sans-serif;font-size:1.75rem;font-weight:800;margin-bottom:.75rem;">Ready to get started?</h3>
    <p style="color:var(--gray-600);margin-bottom:1.5rem;">All features are free to use after creating your account.</p>
    <a href="/signup" class="btn btn-primary btn-lg">Create Free Account →</a>
  </div>

</main>
