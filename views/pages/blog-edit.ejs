<% layout("layouts/boilerplate") %>

<div class="page-hero">
  <div class="max-w-4xl mx-auto">
    <h1 class="page-hero-title">✏️ Edit Blog</h1>
    <p class="page-hero-subtitle">Update your health article</p>
  </div>
</div>

<main class="flex-1 px-6 py-12 max-w-3xl mx-auto w-full">
  <div class="card p-8 anim-scale-in">
    <% if (message) { %>
      <div class="alert alert-success mb-5">✅ <%= message %></div>
    <% } %>
    <form action="/blog/edit/<%= blog._id %>" method="POST" class="space-y-5">
      <div class="form-group">
        <label class="form-label">Blog Title</label>
        <input type="text" name="title" value="<%= blog.title %>" required class="form-input" />
      </div>
      <div class="form-group">
        <label class="form-label">Slug</label>
        <input type="text" name="slug" value="<%= blog.slug %>" required class="form-input" />
      </div>
      <div class="form-group">
        <label class="form-label">Image URL</label>
        <input type="text" name="image" value="<%= blog.image %>" class="form-input" />
      </div>
      <div class="form-group">
        <label class="form-label">Summary</label>
        <textarea name="summary" rows="2" class="form-textarea"><%= blog.summary %></textarea>
      </div>
      <div class="form-group">
        <label class="form-label">Full Content</label>
        <textarea name="content" rows="10" required class="form-textarea"><%= blog.content %></textarea>
      </div>
      <div class="flex gap-3">
        <button type="submit" class="btn btn-primary flex-1">💾 Update Blog</button>
        <a href="/blog" class="btn btn-ghost" style="color:var(--gray-600);">Cancel</a>
      </div>
    </form>
  </div>

<main class="flex-1 px-6 pt-24 pb-12 max-w-4xl mx-auto w-full">

  <h1 class="text-3xl font-bold text-green-600 mb-6">
    ✏️ Edit Blog
  </h1>

  <% if (message) { %>
    <div class="mb-4 text-green-600 font-medium">
      <%= message %>
    </div>
  <% } %>

  <form 
    action="/blog/edit/<%= blog._id %>" 
    method="POST"
    class="space-y-5">

    <div>
      <label class="block mb-1 font-medium">Title</label>
      <input 
        type="text" 
        name="title" 
        value="<%= blog.title %>" 
        required 
        class="w-full border px-4 py-2 rounded" />
    </div>

    <div>
      <label class="block mb-1 font-medium">Slug</label>
      <input 
        type="text" 
        name="slug" 
        value="<%= blog.slug %>" 
        required 
        class="w-full border px-4 py-2 rounded" />
    </div>

    <div>
      <label class="block mb-1 font-medium">Image URL</label>
      <input 
        type="text" 
        name="image" 
        value="<%= blog.image %>" 
        class="w-full border px-4 py-2 rounded" />
    </div>

    <div>
      <label class="block mb-1 font-medium">Summary</label>
      <textarea 
        name="summary" 
        rows="2" 
        class="w-full border px-4 py-2 rounded"><%= blog.summary %></textarea>
    </div>

    <div>
      <label class="block mb-1 font-medium">Content</label>
      <textarea 
        name="content" 
        rows="10" 
        required 
        class="w-full border px-4 py-2 rounded"><%= blog.content %></textarea>
    </div>

    <div class="text-right">
      <button 
        type="submit" 
        class="bg-green-600 text-white px-6 py-2 rounded hover:bg-green-700 transition">
        Update Blog
      </button>
    </div>

  </form>

  <div class="mt-6 text-right">
    <a href="/blog" class="text-green-600 hover:underline">
      ← Back to Blog List
    </a>
  </div>

</main>
