<% layout("layouts/boilerplate") %>
<% title = "Health Blog - Healthit" %>

<div class="page-hero">
  <div class="max-w-6xl mx-auto flex items-center justify-between flex-wrap gap-4">
    <div>
      <h1 class="page-hero-title">📝 Health Blog</h1>
      <p class="page-hero-subtitle">Expert tips on fitness, nutrition, and wellness</p>
    </div>
    <% if (user && user.isAdmin) { %>
      <a href="/blog/add" class="btn btn-primary btn-sm">➕ Add Blog</a>
    <% } %>
  </div>
</div>

<main class="flex-1 px-4 py-14 max-w-6xl mx-auto w-full">

  <% if (blogs.length === 0) { %>
    <div class="text-center py-20">
      <div style="font-size:3rem;margin-bottom:1rem;">📭</div>
      <h3 style="font-family:'Sora',sans-serif;font-size:1.3rem;font-weight:700;margin-bottom:.5rem;">No blogs yet</h3>
      <p style="color:var(--gray-600);">Check back soon for health articles and tips.</p>
    </div>
  <% } else { %>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8">
      <% blogs.forEach((blog, i) => { %>
        <div class="blog-card reveal" style="animation-delay:<%= i * 0.1 %>s">
          <div class="blog-card-img-wrap">
            <img src="<%= blog.image %>" alt="<%= blog.title %>" class="blog-card-img" />
          </div>
          <div class="blog-card-body">
            <span class="blog-card-tag">Health & Fitness</span>
            <h2 class="blog-card-title"><%= blog.title %></h2>
            <p class="blog-card-summary"><%= blog.summary %></p>
          </div>
          <div class="blog-card-footer">
            <a href="/blog/<%= blog.slug %>" style="color:var(--green-600);font-weight:600;font-size:.875rem;text-decoration:none;">Read More →</a>
            <% if (user && user.isAdmin) { %>
              <div style="display:flex;gap:.75rem;align-items:center;">
                <a href="/blog/edit/<%= blog._id %>" class="btn btn-sm" style="padding:.3rem .7rem;background:#eff6ff;color:#3b82f6;border-radius:var(--radius-sm);">✏️</a>
                <form action="/blog/delete/<%= blog._id %>" method="POST" onsubmit="return confirm('Delete this blog?');">
                  <button type="submit" class="btn btn-sm btn-danger" style="padding:.3rem .7rem;">🗑️</button>
                </form>
              </div>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>

</main>