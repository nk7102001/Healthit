<% layout("layouts/boilerplate") %>
<% title = "Change Password - Healthit" %>


<div class="page-hero">
  <div class="max-w-4xl mx-auto">
    <h1 class="page-hero-title">🔐 Change Password</h1>
    <p class="page-hero-subtitle">Keep your account secure with a strong password</p>
  </div>
</div>

<main class="flex-1 px-6 py-12 max-w-xl mx-auto w-full">
  <div class="card p-8 anim-scale-in">
    <% if (message) { %>
      <div class="alert alert-success mb-5">✅ <%= message %></div>
    <% } %>
    <form action="/profile/password" method="POST" class="space-y-5">
      <div class="form-group">
        <label class="form-label">Current Password</label>
        <input type="password" name="currentPassword" required class="form-input" placeholder="Enter current password" />
      </div>
      <div class="form-group">
        <label class="form-label">New Password</label>
        <input type="password" name="newPassword" required class="form-input" placeholder="Create new password" />
      </div>
      <div class="flex gap-3 mt-2">
        <button type="submit" class="btn btn-primary flex-1">Update Password</button>
        <a href="/profile" class="btn btn-ghost flex-1" style="color:var(--gray-600);">Cancel</a>
      </div>
    </form>
  </div>

<main class="flex-1 pt-24 px-6 pb-12">

  <div class="max-w-xl mx-auto bg-green-50 p-6 rounded-lg shadow">

    <h1 class="text-2xl font-bold text-green-600 mb-4">
      🔐 Change Password
    </h1>

    <% if (message) { %>
      <p class="text-sm text-green-600 mb-4">
        <%= message %>
      </p>
    <% } %>

    <form action="/profile/password" method="POST" class="space-y-4">

      <div>
        <label class="block font-medium">Current Password</label>
        <input 
          type="password" 
          name="currentPassword" 
          required 
          class="w-full px-4 py-2 border rounded" />
      </div>

      <div>
        <label class="block font-medium">New Password</label>
        <input 
          type="password" 
          name="newPassword" 
          required 
          class="w-full px-4 py-2 border rounded" />
      </div>

      <button 
        type="submit" 
        class="bg-green-600 text-white px-6 py-2 rounded hover:bg-green-700 transition">
        Change Password
      </button>

    </form>

    <div class="mt-6 text-right">
      <a href="/profile" class="text-green-600 hover:underline">
        ← Back to Profile
      </a>
    </div>

  </div>

</main>
