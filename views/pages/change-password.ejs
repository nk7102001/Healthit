<% layout("layouts/boilerplate") %>
<% title = "Change Password - Healthit" %>

<div class="page-hero">
  <div class="max-w-4xl mx-auto">
    <h1 class="page-hero-title">🔐 Change Password</h1>
    <p class="page-hero-subtitle">Keep your account secure with a strong password</p>
  </div>
</div>

<main class="flex-1 px-6 py-12 max-w-xl mx-auto w-full">
  <div class="card p-8 anim-scale-in">
    <% if (message) { %>
      <div class="alert alert-success mb-5">✅ <%= message %></div>
    <% } %>
    <form action="/profile/password" method="POST" class="space-y-5">
      <div class="form-group">
        <label class="form-label">Current Password</label>
        <input type="password" name="currentPassword" required class="form-input" placeholder="Enter current password" />
      </div>
      <div class="form-group">
        <label class="form-label">New Password</label>
        <input type="password" name="newPassword" required class="form-input" placeholder="Create new password" />
      </div>
      <div class="flex gap-3 mt-2">
        <button type="submit" class="btn btn-primary flex-1">Update Password</button>
        <a href="/profile" class="btn btn-ghost flex-1" style="color:var(--gray-600);">Cancel</a>
      </div>
    </form>
  </div>
</main>