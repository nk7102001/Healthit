<% layout("layouts/boilerplate") %>
<% title = "Healthit - Your AI Fitness Partner" %>

<!-- HERO -->
<section class="hero-bg flex items-center" style="padding-top: 10px; padding-bottom: 40px;">
  <div class="max-w-7xl mx-auto px-6 py-20 w-full">
    <div class="flex flex-col-reverse md:flex-row items-center justify-between gap-12">

      <!-- Left Text -->
      <div class="w-full md:w-1/2 space-y-6">
        <div class="section-badge anim-fade-up">✨ AI-Powered Health Platform</div>
        <h1 class="section-title anim-fade-up delay-1">
          Your Smartest <span class="highlight">Health & Fitness</span> Partner
        </h1>
        <p class="section-subtitle anim-fade-up delay-2">
          Get personalized diet plans, track your progress, calculate BMI, and access health tips — all powered by AI. Your wellness journey starts here.
        </p>
        <div class="flex gap-4 flex-wrap anim-fade-up delay-3">
          <a href="/signup" class="btn btn-primary btn-lg">Get Started Free →</a>
          <a href="/features" class="btn btn-outline btn-lg">Explore Features</a>
        </div>
        <!-- Stats row -->
        <div class="flex gap-8 pt-4 anim-fade-up delay-4">
          <div>
            <div class="font-bold text-2xl" style="font-family:'Sora',sans-serif;color:var(--green-600);">10K+</div>
            <div class="text-sm" style="color:var(--gray-600);">Active Users</div>
          </div>
          <div style="width:1px;background:#e5e7eb;"></div>
          <div>
            <div class="font-bold text-2xl" style="font-family:'Sora',sans-serif;color:var(--green-600);">50K+</div>
            <div class="text-sm" style="color:var(--gray-600);">Plans Generated</div>
          </div>
          <div style="width:1px;background:#e5e7eb;"></div>
          <div>
            <div class="font-bold text-2xl" style="font-family:'Sora',sans-serif;color:var(--green-600);">98%</div>
            <div class="text-sm" style="color:var(--gray-600);">Satisfaction</div>
          </div>
        </div>
      </div>

      <!-- Right Slider -->
      <div class="w-full md:w-1/2 flex justify-center anim-fade-right delay-2">
        <div class="relative w-full max-w-[500px] rounded-2xl overflow-hidden shadow-2xl" style="aspect-ratio:4/3;">
          <img id="slider-image" src="/images/slide1.jpg" class="absolute w-full h-full object-cover slide-image" alt="Health" />
          <!-- Overlay gradient -->
          <div class="absolute inset-0" style="background:linear-gradient(to top,rgba(0,0,0,0.3),transparent);"></div>
          <!-- Dots -->
          <div class="absolute bottom-4 left-1/2 flex gap-2 z-10" style="transform:translateX(-50%);">
            <span class="dot active"></span>
            <span class="dot"></span>
            <span class="dot"></span>
            <span class="dot"></span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- FEATURES PREVIEW -->
<section class="py-20 px-6 bg-white">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-14">
      <div class="section-badge reveal">🌟 What We Offer</div>
      <h2 class="section-title reveal reveal-delay-1">Everything You Need<br>to <span class="highlight">Stay Healthy</span></h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

      <a href="/ai-plan" class="feature-card reveal reveal-delay-1" style="text-decoration:none;display:block;cursor:pointer;">
        <div class="feature-icon-wrap">🤖</div>
        <h3 style="font-family:'Sora',sans-serif;font-weight:700;font-size:1.15rem;margin-bottom:.5rem;color:var(--dark);">AI Diet & Workout Plans</h3>
        <p style="color:var(--gray-600);font-size:.9rem;line-height:1.65;">Personalized plans generated by AI based on your goals, age, and lifestyle preferences.</p>
        <span style="display:inline-block;margin-top:1rem;color:var(--green-600);font-weight:600;font-size:.9rem;">Try it now →</span>
      </a>

      <a href="/bmi" class="feature-card reveal reveal-delay-2" style="text-decoration:none;display:block;cursor:pointer;">
        <div class="feature-icon-wrap">📏</div>
        <h3 style="font-family:'Sora',sans-serif;font-weight:700;font-size:1.15rem;margin-bottom:.5rem;color:var(--dark);">BMI Calculator</h3>
        <p style="color:var(--gray-600);font-size:.9rem;line-height:1.65;">Check your Body Mass Index instantly and track your progress over time with detailed history.</p>
        <span style="display:inline-block;margin-top:1rem;color:var(--green-600);font-weight:600;font-size:.9rem;">Calculate now →</span>
      </a>

      <a href="/nearby" class="feature-card reveal reveal-delay-3" style="text-decoration:none;display:block;cursor:pointer;">
        <div class="feature-icon-wrap">🏥</div>
        <h3 style="font-family:'Sora',sans-serif;font-weight:700;font-size:1.15rem;margin-bottom:.5rem;color:var(--dark);">Find Nearby Hospitals</h3>
        <p style="color:var(--gray-600);font-size:.9rem;line-height:1.65;">Locate hospitals and medical stores near your location in seconds when you need them most.</p>
        <span style="display:inline-block;margin-top:1rem;color:var(--green-600);font-weight:600;font-size:.9rem;">Find now →</span>
      </a>

      <a href="/exercises" class="feature-card reveal reveal-delay-2" style="text-decoration:none;display:block;cursor:pointer;">
        <div class="feature-icon-wrap">🏋️</div>
        <h3 style="font-family:'Sora',sans-serif;font-weight:700;font-size:1.15rem;margin-bottom:.5rem;color:var(--dark);">Home Exercise Library</h3>
        <p style="color:var(--gray-600);font-size:.9rem;line-height:1.65;">Guided video workouts you can do anywhere — no gym required. Filter by muscle group.</p>
        <span style="display:inline-block;margin-top:1rem;color:var(--green-600);font-weight:600;font-size:.9rem;">View exercises →</span>
      </a>

      <a href="/blog" class="feature-card reveal reveal-delay-3" style="text-decoration:none;display:block;cursor:pointer;">
        <div class="feature-icon-wrap">📝</div>
        <h3 style="font-family:'Sora',sans-serif;font-weight:700;font-size:1.15rem;margin-bottom:.5rem;color:var(--dark);">Health Blog</h3>
        <p style="color:var(--gray-600);font-size:.9rem;line-height:1.65;">Expert-written articles on nutrition, fitness, and wellness to keep you informed and motivated.</p>
        <span style="display:inline-block;margin-top:1rem;color:var(--green-600);font-weight:600;font-size:.9rem;">Read blogs →</span>
      </a>

      <a href="/dashboard" class="feature-card reveal reveal-delay-4" style="text-decoration:none;display:block;cursor:pointer;">
        <div class="feature-icon-wrap">📊</div>
        <h3 style="font-family:'Sora',sans-serif;font-weight:700;font-size:1.15rem;margin-bottom:.5rem;color:var(--dark);">Progress Dashboard</h3>
        <p style="color:var(--gray-600);font-size:.9rem;line-height:1.65;">Track your BMI history, saved AI plans, and personal information all in one personalized dashboard.</p>
        <span style="display:inline-block;margin-top:1rem;color:var(--green-600);font-weight:600;font-size:.9rem;">View dashboard →</span>
      </a>

    </div>
  </div>
</section>

<!-- CTA BANNER -->
<section class="reveal py-20 px-6" style="background:linear-gradient(135deg,var(--dark) 0%,var(--dark-2) 100%);">
  <div class="max-w-4xl mx-auto text-center">
    <div class="anim-float" style="font-size:3rem;margin-bottom:1rem;">💚</div>
    <h2 style="font-family:'Sora',sans-serif;font-size:clamp(1.8rem,3vw,2.5rem);font-weight:800;color:white;margin-bottom:1rem;">
      Start Your Health Journey Today
    </h2>
    <p style="color:rgba(255,255,255,0.65);font-size:1.05rem;margin-bottom:2rem;max-width:500px;margin-left:auto;margin-right:auto;">
      Join thousands of people who are already living healthier lives with Healthit.
    </p>
    <% if (typeof user !== 'undefined' && user) { %>
      <a href="/dashboard" class="btn btn-primary btn-lg">Go to Dashboard →</a>
    <% } else { %>
      <a href="/signup" class="btn btn-primary btn-lg">Create Free Account →</a>
    <% } %>
  </div>
</section>
