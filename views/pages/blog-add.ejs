<% layout("layouts/boilerplate") %>

<div class="page-hero">
  <div class="max-w-4xl mx-auto">
    <h1 class="page-hero-title">✍️ Add New Blog</h1>
    <p class="page-hero-subtitle">Write a new health article for your readers</p>
  </div>
</div>

<main class="flex-1 px-6 py-12 max-w-3xl mx-auto w-full">
  <div class="card p-8 anim-scale-in">
    <% if (message) { %>
      <div class="alert alert-success mb-5">✅ <%= message %></div>
    <% } %>
    <form method="POST" action="/blog/add" class="space-y-5">
      <div class="form-group">
        <label class="form-label">Blog Title</label>
        <input type="text" name="title" required class="form-input" placeholder="Enter a compelling title..." />
      </div>
      <div class="form-group">
        <label class="form-label">Slug (URL identifier)</label>
        <input type="text" name="slug" required pattern="^(?!add$).+" title="Slug cannot be 'add'" class="form-input" placeholder="e.g., healthy-morning-routine" />
      </div>
      <div class="form-group">
        <label class="form-label">Summary</label>
        <textarea name="summary" rows="2" required class="form-textarea" placeholder="Short description shown on blog cards..."></textarea>
      </div>
      <div class="form-group">
        <label class="form-label">Image Path</label>
        <input type="text" name="image" value="/images/blog1.jpg" class="form-input" />
      </div>
      <div class="form-group">
        <label class="form-label">Full Content</label>
        <textarea name="content" rows="10" required class="form-textarea" placeholder="Write your full article here..."></textarea>
      </div>
      <div class="flex gap-3">
        <button type="submit" class="btn btn-primary flex-1">➕ Publish Blog</button>
        <a href="/blog" class="btn btn-ghost" style="color:var(--gray-600);">Cancel</a>
      </div>
    </form>
  </div>
</main>