<% layout("layouts/boilerplate") %>
<% title = "Edit Profile - Healthit" %>

<div class="page-hero">
  <div class="max-w-4xl mx-auto">
    <h1 class="page-hero-title">✏️ Edit Profile</h1>
    <p class="page-hero-subtitle">Update your personal information</p>
  </div>
</div>

<main class="flex-1 px-6 py-12 max-w-xl mx-auto w-full">
  <div class="card p-8 anim-scale-in">
    <% if (message) { %>
      <div class="alert alert-error mb-5">⚠️ <%= message %></div>
    <% } %>
    <form action="/profile/edit" method="POST" class="space-y-5">
      <div class="form-group">
        <label class="form-label">Full Name</label>
        <input type="text" name="name" value="<%= user.name %>" required class="form-input" />
      </div>
      <div class="form-group">
        <label class="form-label">Email Address</label>
        <input type="email" name="email" value="<%= user.email %>" required class="form-input" />
      </div>
      <div class="flex gap-3 mt-2">
        <button type="submit" class="btn btn-primary flex-1">Save Changes</button>
        <a href="/profile" class="btn btn-ghost flex-1" style="color:var(--gray-600);">Cancel</a>
      </div>
    </form>
  </div>
</main>
