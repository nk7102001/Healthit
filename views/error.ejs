<%= layout("/layouts/boilerplate") %>

<div class="flex justify-center items-center min-h-screen px-4" style="padding-top:5rem;">
  <div class="card p-10 max-w-lg w-full text-center anim-scale-in">
    <div style="font-size:3rem;margin-bottom:1rem;">⚠️</div>
    <h1 style="font-family:'Sora',sans-serif;font-size:1.5rem;font-weight:800;color:var(--dark);margin-bottom:.75rem;">Something went wrong</h1>
    <p style="color:#dc2626;background:#fef2f2;border:1px solid #fecaca;padding:.85rem 1.1rem;border-radius:var(--radius-sm);font-weight:500;"><%= message %></p>
    <div class="flex gap-3 justify-center mt-6">
      <a href="/" class="btn btn-primary">Go Home</a>
      <button onclick="history.back()" class="btn btn-outline">Go Back</button>
    </div>
  </div>
</div>
